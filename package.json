{
  "name": "directus-extension-sap-service-layer",
  "version": "1.0.0",
  "type": "module",
  "directus:extension": {
    "type": "bundle",
    "host": "^10.0.0 || ^11.0.0",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "entries": [
      { "type": "operation", "name": "sap-login", "source": { "app": "src/login/app.js", "api": "src/login/api.js" } },
      { "type": "operation", "name": "sap-logout", "source": { "app": "src/logout/app.js", "api": "src/logout/api.js" } },
      { "type": "operation", "name": "sap-request", "source": { "app": "src/request/app.js", "api": "src/request/api.js" } },
      { "type": "hook", "name": "sap-auto-login", "source": "src/hooks/sap-auto-login.js" }
    ]
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^12.0.0"
  }
}
